# Arceion-Zorion Django Settings
# Copy to .env.local and update with your values
# NOTE: .env.local should NOT be committed to version control

# Django Core Settings
SECRET_KEY=your-secret-key-here-minimum-50-characters-long-randomly-generated
DEBUG=False
ENVIRONMENT=production

# Security
ALLOWED_HOSTS=localhost,127.0.0.1,example.com
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
CORS_ALLOW_ALL=False

# Database Configuration (if using custom database)
# Examples:
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# DATABASE_URL=mysql://user:password@localhost:3306/dbname
# DATABASE_URL=sqlite:///db.sqlite3

# JWT Configuration (if using JWT authentication)
JWT_SECRET=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Email Configuration (if using email)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=True

# Logging Configuration
LOG_LEVEL=INFO

# AWS Configuration (if using S3 or other AWS services)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1

# Third-party Services
# Add any other environment variables your application needs here
